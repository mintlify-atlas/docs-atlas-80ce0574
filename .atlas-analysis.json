{
  "projectType": "framework",
  "projectName": "Oxichrome",
  "projectDescription": "A Rust framework for building browser extensions that compile to WebAssembly, with proc macro annotations, type-safe Chrome API bindings, and Leptos for reactive UI — no JavaScript required.",
