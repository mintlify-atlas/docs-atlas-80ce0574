  "keyFeatures": [
    "Five proc macros (#[extension], #[background], #[on], #[popup], #[options_page], #[content_script]) transform Rust into wasm-bindgen exports",
    "Type-safe bindings to chrome.storage, chrome.tabs, and chrome.runtime APIs",
    "Leptos integration for reactive popup and options page UI",
    "cargo oxichrome build CLI handles compilation, wasm-bindgen, manifest generation, JS/HTML shim generation, and optional wasm-opt",
    "Firefox support via --target firefox with Manifest V3 compatibility",
    "Zero hand-written JavaScript — compiles entirely to WebAssembly"
  ],
  "publicApiSurface": [
    "#[oxichrome::extension(...)]",
    "#[oxichrome::background]",
    "#[oxichrome::on(namespace::event)]",
    "#[oxichrome::popup]",
    "#[oxichrome::options_page]",
    "#[oxichrome::content_script(matches = [...])]",
    "oxichrome::storage::get(key)",
    "oxichrome::storage::set(key, value)",
    "oxichrome::storage::remove(key)",
    "oxichrome::tabs::query(query_info)",
    "oxichrome::tabs::create(props)",
    "oxichrome::tabs::send_message(tab_id, message)",
    "oxichrome::runtime::get_url(path)",
    "oxichrome::runtime::send_message(message)",
    "oxichrome::log!(...)",
    "cargo oxichrome build",
    "cargo oxichrome build --release",
    "cargo oxichrome build --target firefox",
    "cargo oxichrome new <name>",
    "cargo oxichrome clean"
  ]
}
